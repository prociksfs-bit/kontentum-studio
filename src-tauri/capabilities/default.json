{
  "$schema": "https://raw.githubusercontent.com/nicedoc/schemas/main/tauri/capability.json",
  "identifier": "default",
  "description": "Main capability for the КОНТЕНТУМ Studio app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "dialog:default",
    "fs:default",
    "clipboard-manager:allow-write-text",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install",
    "process:allow-restart",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://*.xn--e1ajhcbd3acj.xn--p1ai/**" },
        { "url": "https://xn--e1ajhcbd3acj.xn--p1ai/**" },
        { "url": "https://api.github.com/**" },
        { "url": "https://github.com/**" },
        { "url": "https://*.github.com/**" }
      ]
    }
  ]
}
