{
  "$schema": "https://raw.githubusercontent.com/nicedoc/schemas/main/tauri/tauri.conf.json",
  "productName": "КОНТЕНТУМ Studio",
  "version": "0.9.0",
  "identifier": "ru.kontentum.studio",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "КОНТЕНТУМ Studio",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "useHttpsScheme": true
      }
    ],
    "security": {
      "csp": "default-src 'self' https://tauri.localhost; connect-src 'self' https://tauri.localhost wss://* ws://* https://*; media-src 'self' https://tauri.localhost mediastream: blob:; img-src 'self' https://tauri.localhost data: blob:; script-src 'self' https://tauri.localhost 'unsafe-inline'; style-src 'self' https://tauri.localhost 'unsafe-inline'; font-src 'self' https://tauri.localhost https://fonts.googleapis.com https://fonts.gstatic.com data:"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/prociksfs-bit/kontentum-studio/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENFMzYzM0M1Qzc1QTc4NTcKUldSWGVGckh4VE0yemgrNWxxZ08xQlFoZnErVHFjY0wzeXZscmg5SFFUOFk2eVJla00rNFdXYlUK"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": "v2",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "languages": ["Russian", "English"],
        "displayLanguageSelector": false
      },
      "wix": {
        "language": ["ru-RU", "en-US"]
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "./Entitlements.plist",
      "signingIdentity": "-"
    }
  }
}
